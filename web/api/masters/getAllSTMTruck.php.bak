$entityVAContent = json_decode(file_get_contents("php://input"));
if($entityVAContent->formType=="QCDET" || $entityVAContent->formType=="QCDET_STM"){
  echo fetchAllTruckArrivalDet($connect, $entityVAContent);
}else if($entityVAContent->formType=="WEIGHTENTRYDET"){
  echo fetchAllTruckArrival_WeightDet($connect, $entityVAContent);
}else{
echo fetchAllTruckArrival($connect, $entityVAContent);
}
$connect->close();

function fetchAllTruckArrival_WeightDet($connect, $record)
{
  $screenType = mysqli_real_escape_string($connect, $record->SCREEN_TYPE);
  $ScreenName=$record->ScreenName;
  
  $conditions = count($record->plantIds)<=0? []: ["PLANT_ID in ('" . join("','", $record->plantIds) . "')"];
  
  if(isset($record->status) && $record->status){
     array_push($conditions, "VEHICLE_STATUS IN ($record->status)");
  }
  $st = "";
 
  if (isset($record->searchTxt)) {
    $st = "'%" . mysqli_real_escape_string($connect, trim($record->searchTxt)) . "%'";
    if ($screenType == "EVAOY") {
      
      array_push(
        $conditions,
        "(ZVA_NUMBER like " . $st ."
         or TRAILER_NO like " .$st ." 
         or TRUCK_NO like " .$st ." 
         or CONTAINER_NO like " .
          $st .
          " or DRIVER_NO like " .
          $st .
          " or WB_NAME like " .
          $st .
          " or PLANT_ID like " .
          $st .
          ")"
      );
    } elseif ($screenType == "EVADP") {
      array_push($conditions, "(ZVA_NUMBER like " .
      $st .
      " or TRAILER_NO like " . $st . "   or TRUCK_NO like " .$st ." or DRIVER_NO like " . $st . " or PLANT_ID like " . $st . ")");
    } elseif ($screenType == "EVAWH") {
      array_push(
        $conditions,
        "(ZVA_NUMBER like " .
        $st .
        " or TRUCK_NO like " .
          $st .
          " or DRIVER_NO like " .
          $st .
          " or WB_TICKET_NO like " .
          $st .
          " or WB_NAME like " .
          $st .
          " or PLANT_ID like " .
          $st .
          ")"
      );
    }
  }
 
  //array_push($conditions, "SCREEN_TYPE='$screenType'");
 
  if ($screenType == "SILOTOMILL") {
  array_push($conditions, "(SCREEN_TYPE='SILOTOMILL')");
  }

  if($record->TRUCK_NO){
    array_push($conditions, "TRUCK_NO='".$record->TRUCK_NO."'");
  }
  
  if($screenType==="EVADP" && isset($record->isTruck) ){
    if($record->isTruck){
      array_push($conditions, "(TRUCK_NO<>'' or TRUCK_NO is not null)");
    }
    else{
      array_push($conditions, "(TRAILER_NO<>'' or TRAILER_NO is not null)");
    }
  }
  
  if(isset($record->otherfilter)){
    $FromDt=$record->otherfilter->otherfilter->from;
    $ToDt=$record->otherfilter->otherfilter->to;
   //  $PlantId=$record->otherfilter->otherfilter->PlantId;
   // echo $FromDt;
    array_push($conditions,"DATE(DateAdded) >= '".$FromDt."'");
    array_push($conditions,"DATE(DateAdded) <= '".$ToDt."'");
    if($PlantId!=""){
    array_push($conditions,"PLANT_ID = '".$PlantId."'");
    }
    //var_dump($filter);

    if($record->otherfilter->otherfilter->PlantIdArr!=null && sizeof($record->otherfilter->otherfilter->PlantIdArr)>0){
      $PlantIdArray=$record->otherfilter->otherfilter->PlantIdArr;
     $PlantIdArrFilter=" (";
     for($i=0;$i<sizeof($PlantIdArray);$i++){
        $PlantIdArrFilter.="a.WERKS = '".$PlantIdArray[$i]->value."' OR ";
     }
     $PlantIdArrFilter=rtrim($PlantIdArrFilter,"OR ");
     $PlantIdArrFilter.=")";
     array_push($filters,$PlantIdArrFilter);
    }
  }
  
  if(isset($record->PurchaseInfoId) && $record->PurchaseInfoId>0){
    array_push($conditions,"PI_REFID = '".$record->PurchaseInfoId."'");
  }
  else if(isset($record->ID)){
    array_push($conditions,"ID = '".$record->ID."'");
  }

  if(isset($record->PurchaseInfoId) && $record->PurchaseInfoId>0){
    array_push($conditions,"PI_REFID = '".$record->PurchaseInfoId."'");
    $countsql = "select count(PI_REFID) as total from purchase_info where ".join(" and ", $conditions);
  }else{
    $countsql = "select count(ID) as total from empty_vehicle_arrival where ".join(" and ", $conditions);
  }
  
 // echo $countsql;exit();
  $total = getFieldValue($connect, $countsql, 0);

  $pageSize =50;
  if(isset($record->pageSize)){
    $pageSize =$record->pageSize;
  }

  if(isset($record->PurchaseInfoId) && $record->PurchaseInfoId>0){
    
    $fetchsql =
    "select *,'$ScreenName' as ScreenName,date_format(DateAdded,'%d-%m-%Y %h:%i %p') as VADate,
    date_format(GateOutDt,'%d-%m-%Y %h:%i %p') as GateOutDateTime
    
    from purchase_info where ". join(" and ", $conditions) . " order by PI_REFID desc limit " . $record->startCount . ",$pageSize";
   // echo $fetchsql;exit();
    $tableRecords = getResultAsObjectArray($connect, $fetchsql);
  }else{
    $fetchsql =
    "select *,'$ScreenName' as ScreenName,date_format(DateAdded,'%d-%m-%Y %h:%i %p') as VADate,
    date_format(GateOutDt,'%d-%m-%Y %h:%i %p') as GateOutDateTime
    
    from empty_vehicle_arrival where ". join(" and ", $conditions) . " order by ID desc limit " . $record->startCount . ",$pageSize";
    //echo $fetchsql;exit();
    $tableRecords = getResultAsObjectArray($connect, $fetchsql);
  }
  
 


  $DispDet =
    "SELECT * FROM `silotomill_dispatch_info` where VehicleArrivalId='".$record->ID."'";
  $DispDetRecords = getResultAsObjectArray($connect, $DispDet);

 // var_dump($tableRecords);
  $QCDataQ =
  "SELECT * FROM `stm_silotomillqcdet` where VANumber='".$tableRecords[0]['ZVA_NUMBER']."'";
$QCData = getResultAsObjectArray($connect, $QCDataQ);

$Weight =
"SELECT * FROM `pp_silotomillweights` where VANumber='".$tableRecords[0]['ZVA_NUMBER']."'";
$WeightDetails = getResultAsObjectArray($connect, $Weight);

$Weight =
"SELECT * FROM `pp_silotomillweights_unload` where VANumber='".$tableRecords[0]['ZVA_NUMBER']."'";
$UnloadWeightDetails = getResultAsObjectArray($connect, $Weight);

$Weight =
"SELECT * FROM `silotomill_gateout_info` where EmptyVehicleArrivalId='".$tableRecords[0]['ID']."'";
$silotomillunload_gateout_info = getResultAsObjectArray($connect, $Weight);


$Weight =
"SELECT VECHICAL_STATUS FROM `purchase_info` where EMPTY_VEHICLE_ARRIVAL_ID='".$tableRecords[0]['ID']."'";
$poresults = getResultAsObjectArray($connect, $Weight);
 
 
  return json_encode(["success" => 1,"UnloadWeightDetails"=>$UnloadWeightDetails,"poresults"=>$poresults,"silotomillunload_gateout_info"=>$silotomillunload_gateout_info, "WeightDetails"=>$WeightDetails,"results" => $tableRecords,"QCData"=>$QCData, "DispDetRecords"=>$DispDetRecords,"count" => $total]);

}
function fetchAllTruckArrivalDet($connect, $record)
{
 // echo "test";exit();
  $screenType = mysqli_real_escape_string($connect, $record->SCREEN_TYPE);
  $ScreenName=$record->ScreenName;

  $conditions = count($record->plantIds)<=0? []: ["PLANT_ID in ('" . join("','", $record->plantIds) . "')"];
  
  if(isset($record->status) && $record->status){
     array_push($conditions, "VEHICLE_STATUS IN ($record->status)");
  }
  $st = "";
 
  if (isset($record->searchTxt)) {
    $st = "'%" . mysqli_real_escape_string($connect, trim($record->searchTxt)) . "%'";
    if ($screenType == "EVAOY") {
      
      array_push(
        $conditions,
        "(ZVA_NUMBER like " . $st ."
         or TRAILER_NO like " .$st ." 
         or TRUCK_NO like " .$st ." 
         or CONTAINER_NO like " .
          $st .
          " or DRIVER_NO like " .
          $st .
          " or WB_NAME like " .
          $st .
          " or PLANT_ID like " .
          $st .
          ")"
      );
    } elseif ($screenType == "EVADP") {
      array_push($conditions, "(ZVA_NUMBER like " .
      $st .
      " or TRAILER_NO like " . $st . "   or TRUCK_NO like " .$st ." or DRIVER_NO like " . $st . " or PLANT_ID like " . $st . ")");
    } elseif ($screenType == "EVAWH") {
      array_push(
        $conditions,
        "(ZVA_NUMBER like " .
        $st .
        " or TRUCK_NO like " .
          $st .
          " or DRIVER_NO like " .
          $st .
          " or WB_TICKET_NO like " .
          $st .
          " or WB_NAME like " .
          $st .
          " or PLANT_ID like " .
          $st .
          ")"
      );
    }
  }
 
  //array_push($conditions, "SCREEN_TYPE='$screenType'");
 
  if ($screenType == "SILOTOMILL") {
  array_push($conditions, "(SCREEN_TYPE='SILOTOMILL')");
  }

  if($record->TRUCK_NO){
    array_push($conditions, "TRUCK_NO='".$record->TRUCK_NO."'");
  }
  
  if($screenType==="EVADP" && isset($record->isTruck) ){
    if($record->isTruck){
      array_push($conditions, "(TRUCK_NO<>'' or TRUCK_NO is not null)");
    }
    else{
      array_push($conditions, "(TRAILER_NO<>'' or TRAILER_NO is not null)");
    }
  }
  
  if(isset($record->otherfilter)){
    $FromDt=$record->otherfilter->otherfilter->from;
    $ToDt=$record->otherfilter->otherfilter->to;
   //  $PlantId=$record->otherfilter->otherfilter->PlantId;
   // echo $FromDt;
    array_push($conditions,"DATE(DateAdded) >= '".$FromDt."'");
    array_push($conditions,"DATE(DateAdded) <= '".$ToDt."'");
    if($PlantId!=""){
    array_push($conditions,"PLANT_ID = '".$PlantId."'");
    }
    //var_dump($filter);

    if($record->otherfilter->otherfilter->PlantIdArr!=null && sizeof($record->otherfilter->otherfilter->PlantIdArr)>0){
      $PlantIdArray=$record->otherfilter->otherfilter->PlantIdArr;
     $PlantIdArrFilter=" (";
     for($i=0;$i<sizeof($PlantIdArray);$i++){
        $PlantIdArrFilter.="a.WERKS = '".$PlantIdArray[$i]->value."' OR ";
     }
     $PlantIdArrFilter=rtrim($PlantIdArrFilter,"OR ");
     $PlantIdArrFilter.=")";
     array_push($filters,$PlantIdArrFilter);
    }
  }
  
  if($record->ID){
    array_push($conditions,"ID = '".$record->ID."'");
  }
 
  $countsql = "select count(ID) as total from empty_vehicle_arrival where ".join(" and ", $conditions);
 // echo $countsql;
  //exit();
  $total = getFieldValue($connect, $countsql, 0);

  $pageSize =50;
  if(isset($record->pageSize)){
    $pageSize =$record->pageSize;
  }

  $fetchsql =
    "select *,'$ScreenName' as ScreenName,date_format(DateAdded,'%d-%m-%Y %h:%i %p') as VADate,
    date_format(GateOutDt,'%d-%m-%Y %h:%i %p') as GateOutDateTime
    
    from empty_vehicle_arrival where ". join(" and ", $conditions) . " order by ID desc limit " . $record->startCount . ",$pageSize";
    //echo $fetchsql;exit();
    $tableRecords = getResultAsObjectArray($connect, $fetchsql);

    $VaNumber=$tableRecords[0]['ZVA_NUMBER'];
    $EmptyVehArrivalId=$tableRecords[0]['ID'];


  $DispDet =
    "SELECT a.*,
    concat(a.ReceivingPlant,'-',b.PLANT_NAME) as ReceivingPlantName,
    concat(a.StorageLocation,'-',c.STORAGE_LOCATION) as ReceivingStorageLocationName,date_format(a.DeliveryDate,'%d-%m-%Y') as DeliveryDate
    FROM `silotomill_dispatch_info` a 
    LEFT JOIN master_plant b ON a.ReceivingPlant=b.WERKS
    LEFT JOIN master_storage c ON a.StorageLocation=c.LGORT
    where a.VehicleArrivalId='".$EmptyVehArrivalId."'";
    //echo $DispDet;exit();
  $DispDetRecords = getResultAsObjectArray($connect, $DispDet);
  //var_dump($DispDetRecords);

   $Whtdt = "SELECT * FROM `pp_silotomillpoline` where PONumber='".$DispDetRecords[0]['ZPO_NUMBER']."' and LineItem='".$DispDetRecords[0]['PO_LINE_ITEM']."'";
