  "SELECT *,2_3_MM as MM23,1000Kernel as Kernel1000 FROM `stm_silotomillqcdet` where VANumber='".$tableRecords[0]['ZVA_NUMBER']."'";
$QCData = getResultAsObjectArray($connect, $QCDataQ);

$QCDataQ =
  "SELECT * FROM `quality_info` where STM_VehicleArrivalId='$EmptyVehArrivalId'";
